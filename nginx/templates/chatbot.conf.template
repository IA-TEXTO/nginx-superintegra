server {
    listen 80;
    server_name $ {
        CHATBOT_INTEGRACAR_DOMAI
    }
    ;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name $ {
        CHATBOT_INTEGRACAR_DOMAI
    }
    ;

    ssl_certificate /etc/nginx/certs/origin.crt;
    ssl_certificate_key /etc/nginx/certs/origin.key;

    resolver 127.0.0.11 valid=30s;

    location / {